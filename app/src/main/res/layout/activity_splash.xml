<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1B1B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KA"
            android:textColor="#F5C518"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="॥"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AR"
            android:textColor="#F5C518"
            android:textSize="56sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="KABADDI ARENA"
        android:textColor="#F5C518"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your Personal Kabaddi Scout"
        android:textColor="#AAAAAA"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnNewMatch"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="60dp"
        android:backgroundTint="#F5C518"
        android:text="START NEW MATCH"
        android:textColor="#1B1B1B"
        android:textStyle="bold"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnViewStats"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2E2E2E"
        android:text="VIEW MY STATS"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2E2E2E"
        android:text="MY PROFILE"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1B1B"
    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Scroll hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▼ Scroll down for counters and END MATCH"
            android:textColor="#F5C518"
            android:textSize="12sp"
            android:gravity="center"
            android:background="#2E2E2E"
            android:padding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Header -->
        <TextView
            android:id="@+id/tvOpponent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="vs Opponent"
            android:textColor="#F5C518"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Live Stats Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#2E2E2E"
            app:cardCornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTotalPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Points: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRaidSuccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Raid Success: N/A"
                    android:textColor="#F5C518"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvTackleSuccess"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tackle Success: N/A"
                    android:textColor="#F5C518"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Raid Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAID ACTIONS"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnEmptyRaid"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#3A3A3A"
            android:text="EMPTY RAID"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTouchPoint"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1B5E20"
            android:text="TOUCH POINT ✓"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBonusPoint"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#1A237E"
            android:text="BONUS POINT ★"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Tackle Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TACKLE ACTIONS"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSuperTackle"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#B71C1C"
            android:text="SUPER TACKLE 💥"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTackleSuccess"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#E65100"
            android:text="TACKLE SUCCESS 🤼"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Counts Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#2E2E2E"
            app:cardCornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CURRENT MATCH COUNTS"
                    android:textColor="#F5C518"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvEmptyRaids"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Empty Raids: 0"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTouchPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Touch Points: 0"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvBonusPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bonus Points: 0"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvSuperTackles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Super Tackles: 0"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTackleSuccessCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tackle Success: 0"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Undo -->
        <Button
            android:id="@+id/btnUndo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4A4A4A"
            android:text="↩ UNDO LAST ACTION"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- End Match -->
        <Button
            android:id="@+id/btnEndMatch"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#F5C518"
            android:text="⏹ END MATCH"
            android:textColor="#1B1B1B"
            android:textStyle="bold"
            android:textSize="20sp" />

    </LinearLayout>
</ScrollView>